rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function belongsToOrg(orgId) {
      return request.auth != null
        && (
          request.auth.token.organization_id == orgId
          || request.auth.uid == orgId
        );
    }

    function canWriteToOrg(orgId) {
      return request.auth != null
        && (
          request.auth.token.organization_id == orgId
          || request.auth.uid == orgId
        );
    }

    function isClientRole() {
      return request.auth != null && request.auth.token.role == 'client';
    }

    function clientOwnsClientDoc(clientId) {
      return !isClientRole()
        || (request.auth.token.client_id != null
            && request.auth.token.client_id == clientId);
    }

    function clientOwnsResource() {
      return !isClientRole()
        || (request.auth.token.client_id != null
            && resource.data.clientId == request.auth.token.client_id);
    }

    match /users/{userId} {
      allow read: if request.auth != null 
        && (request.auth.uid == userId || belongsToOrg(resource.data.organization_id));
      allow write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /team_invitations/{inviteId} {
      allow read: if belongsToOrg(resource.data.organization_id);
      allow write: if belongsToOrg(resource.data.organization_id) 
        && (request.auth.token.role == 'owner' || request.auth.token.role == 'admin');
      allow create: if belongsToOrg(request.resource.data.organization_id)
        && (request.auth.token.role == 'owner' || request.auth.token.role == 'admin');
    }

    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow write: if false;
    }

    match /clients/{clientId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsClientDoc(clientId);
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /projects/{projectId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /tasks/{taskId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /messages/{messageId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /updates/{updateId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /whiteboards/{whiteboardId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    // --- Direct chat conversations between agency and clients ---
    match /chats/{chatId} {
      // Agency staff can read/update their own org's conversations.
      // belongsToOrg checks token claim OR uid — no custom claim required for owners.
      allow read, update: if belongsToOrg(resource.data.organization_id);
      allow create: if canWriteToOrg(request.resource.data.organization_id);
      allow delete: if false;

      // Messages subcollection.
      // We use get() on the parent chat doc to resolve the org — this avoids relying
      // on resource.data which is unreliable for list/query operations, and avoids
      // needing a denormalized organization_id in every message doc.
      match /messages/{messageId} {
        function parentOrg() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.organization_id;
        }

        // Agency: read all messages if they belong to the org
        allow read: if request.auth != null && belongsToOrg(parentOrg());

        // Agency: create messages in their own org's chat (Admin SDK handles this,
        // but rule allows direct writes too for flexibility)
        allow create: if request.auth != null && canWriteToOrg(parentOrg());

        // Clients: read + write their own thread via client_id claim
        allow read: if isClientRole()
          && request.auth.token.client_id != null;
        allow create: if isClientRole()
          && request.auth.token.client_id != null
          && request.resource.data.senderRole == 'client';

        allow update, delete: if false;
      }
    }
  }
}
