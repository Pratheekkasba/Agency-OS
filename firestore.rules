rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: check user belongs to the org of this doc ───────────────
    function belongsToOrg(orgId) {
      return request.auth != null
        && request.auth.token.organization_id == orgId;
    }

    // ─── Users ────────────────────────────────────────────────────────────
    // A user can only read/write their own profile doc
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Organizations ────────────────────────────────────────────────────
    // Members can only read their own org; no client-side writes allowed
    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow write: if false; // Only Admin SDK (server-side) may write orgs
    }

    // ─── Clients ─────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read, update, delete: if belongsToOrg(resource.data.organization_id);
      allow create: if request.auth != null
        && request.auth.token.organization_id == request.resource.data.organization_id;
    }

    // ─── Projects ────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read, update, delete: if belongsToOrg(resource.data.organization_id);
      allow create: if request.auth != null
        && request.auth.token.organization_id == request.resource.data.organization_id;
    }

    // ─── Tasks ───────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read, update, delete: if belongsToOrg(resource.data.organization_id);
      allow create: if request.auth != null
        && request.auth.token.organization_id == request.resource.data.organization_id;
    }

    // ─── Messages ────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read, update, delete: if belongsToOrg(resource.data.organization_id);
      allow create: if request.auth != null
        && request.auth.token.organization_id == request.resource.data.organization_id;
    }

    // ─── Updates ─────────────────────────────────────────────────────────
    match /updates/{updateId} {
      allow read, update, delete: if belongsToOrg(resource.data.organization_id);
      allow create: if request.auth != null
        && request.auth.token.organization_id == request.resource.data.organization_id;
    }

    // ─── Whiteboards ─────────────────────────────────────────────────────
    match /whiteboards/{whiteboardId} {
      allow read, update, delete: if belongsToOrg(resource.data.organization_id);
      allow create: if request.auth != null
        && request.auth.token.organization_id == request.resource.data.organization_id;
    }
  }
}