rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Clients: any authenticated user can read clients matching their agencyId,
    // and create clients where agencyId == their own uid (agency owners).
    // For MVP we use auth-only guard; agencyId filtering is enforced in queries.
    match /clients/{clientId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Updates: any authenticated user can read and create updates.
    // agencyId isolation is enforced by query-side where() filters.
    match /updates/{updateId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Legacy collections
    match /tasks/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /messages/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}