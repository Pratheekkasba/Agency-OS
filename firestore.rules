rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function belongsToOrg(orgId) {
      return request.auth != null
        && (
          request.auth.token.organization_id == orgId
          || request.auth.uid == orgId
        );
    }

    function canWriteToOrg(orgId) {
      return request.auth != null
        && (
          request.auth.token.organization_id == orgId
          || request.auth.uid == orgId
        );
    }

    function isClientRole() {
      return request.auth != null && request.auth.token.role == 'client';
    }

    function clientOwnsClientDoc(clientId) {
      return !isClientRole()
        || (request.auth.token.client_id != null
            && request.auth.token.client_id == clientId);
    }

    function clientOwnsResource() {
      return !isClientRole()
        || (request.auth.token.client_id != null
            && resource.data.clientId == request.auth.token.client_id);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow write: if false;
    }

    match /clients/{clientId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsClientDoc(clientId);
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /projects/{projectId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /tasks/{taskId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /messages/{messageId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /updates/{updateId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }

    match /whiteboards/{whiteboardId} {
      allow read: if belongsToOrg(resource.data.organization_id)
        && clientOwnsResource();
      allow update, delete: if canWriteToOrg(resource.data.organization_id)
        && !isClientRole();
      allow create: if canWriteToOrg(request.resource.data.organization_id)
        && !isClientRole();
    }
  }
}
